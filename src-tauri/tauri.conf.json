{
  "productName": "RustOpti",
  "version": "2.2.4",
  "identifier": "com.rustopti.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "RustOpti",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https:"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZDQzhDRDBFQjlBMjQwMTIKUldRU1FLSzVEczNJYk04QUZpVUdVcWszY0ppZTdhVWsySE1aSjJTNEtTU0FZNjJGMFMrRkZXNUMK",
      "endpoints": [
        "https://github.com/BENDE4a/rustopti/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
